/**
 * Classroom Linking Modal
 * Allows students to enter classroom code to link to teacher dashboard
 */

class ClassroomLinking {
  constructor() {
    this.modal = null;
  }

  /**
   * Check if user needs to link to classroom
   */
  async checkLinkingRequired() {
    const { classroom_id, hasSeenLinkingPrompt } = await chrome.storage.sync.get([
      'classroom_id',
      'hasSeenLinkingPrompt'
    ]);

    // Skip if already linked or user dismissed
    if (classroom_id || hasSeenLinkingPrompt) {
      return false;
    }

    return true;
  }

  /**
   * Show classroom linking modal
   */
  async showLinkingModal() {
    this.modal = document.createElement('div');
    this.modal.className = 'lb-classroom-linking-modal';
    this.modal.innerHTML = `
      <div class="lb-linking-overlay"></div>
      <div class="lb-linking-content">
        <div class="lb-linking-header">
          <h2>🏫 Link to Your Classroom</h2>
          <p>Connect to your teacher's dashboard to track your progress</p>
        </div>

        <div class="lb-linking-body">
          <div class="lb-code-input-group">
            <label for="lb-classroom-code">Classroom Code</label>
            <input
              type="text"
              id="lb-classroom-code"
              placeholder="e.g. ABC-1234"
              maxlength="8"
              style="text-transform: uppercase;"
            />
            <small>Ask your teacher for this code</small>
          </div>

          <div id="lb-linking-error" class="lb-linking-error" style="display: none;"></div>
          <div id="lb-linking-success" class="lb-linking-success" style="display: none;">
            ✅ Successfully linked to classroom!
          </div>
        </div>

        <div class="lb-linking-footer">
          <button id="lb-link-classroom-btn" class="lb-btn-primary">Link Classroom</button>
          <button id="lb-skip-linking-btn" class="lb-btn-secondary">Skip for Now</button>
        </div>

        <div class="lb-linking-privacy">
          <small>🔒 Privacy: Only anonymous usage stats are tracked. Your teacher won't see what you're translating.</small>
        </div>
      </div>
    `;

    document.body.appendChild(this.modal);
    this.addStyles();
    this.attachEventListeners();
  }

  /**
   * Add styles for modal
   */
  addStyles() {
    const style = document.createElement('style');
    style.textContent = `
      .lb-classroom-linking-modal {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 999999;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      }
      .lb-linking-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.6);
        backdrop-filter: blur(4px);
      }
      .lb-linking-content {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        background: white;
        border-radius: 16px;
        padding: 32px;
        max-width: 480px;
        width: 90%;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
      }
      .lb-linking-header h2 {
        margin: 0 0 8px 0;
        font-size: 24px;
        color: #1a1a1a;
      }
      .lb-linking-header p {
        margin: 0 0 24px 0;
        color: #666;
        font-size: 14px;
      }
      .lb-code-input-group {
        margin-bottom: 20px;
      }
      .lb-code-input-group label {
        display: block;
        margin-bottom: 8px;
        font-weight: 600;
        color: #333;
      }
      .lb-code-input-group input {
        width: 100%;
        padding: 12px 16px;
        border: 2px solid #e0e0e0;
        border-radius: 8px;
        font-size: 18px;
        font-weight: 600;
        letter-spacing: 2px;
        transition: border-color 0.2s;
        box-sizing: border-box;
      }
      .lb-code-input-group input:focus {
        outline: none;
        border-color: #7c3aed;
      }
      .lb-code-input-group small {
        display: block;
        margin-top: 6px;
        color: #666;
        font-size: 12px;
      }
      .lb-linking-error {
        padding: 12px;
        background: #fef2f2;
        border: 1px solid #fecaca;
        border-radius: 8px;
        color: #dc2626;
        font-size: 14px;
        margin-bottom: 16px;
      }
      .lb-linking-success {
        padding: 12px;
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
        border-radius: 8px;
        color: #16a34a;
        font-size: 14px;
        margin-bottom: 16px;
      }
      .lb-linking-footer {
        display: flex;
        gap: 12px;
        margin-top: 24px;
      }
      .lb-btn-primary,
      .lb-btn-secondary {
        flex: 1;
        padding: 12px 24px;
        border: none;
        border-radius: 8px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
      }
      .lb-btn-primary {
        background: linear-gradient(135deg, #7c3aed 0%, #a855f7 100%);
        color: white;
      }
      .lb-btn-primary:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(124, 58, 237, 0.3);
      }
      .lb-btn-primary:disabled {
        opacity: 0.6;
        cursor: not-allowed;
      }
      .lb-btn-secondary {
        background: #f3f4f6;
        color: #666;
      }
      .lb-btn-secondary:hover {
        background: #e5e7eb;
      }
      .lb-linking-privacy {
        margin-top: 20px;
        padding-top: 20px;
        border-top: 1px solid #e0e0e0;
        text-align: center;
        color: #666;
      }
    `;
    document.head.appendChild(style);
  }

  /**
   * Attach event listeners
   */
  attachEventListeners() {
    const linkBtn = document.getElementById('lb-link-classroom-btn');
    const skipBtn = document.getElementById('lb-skip-linking-btn');
    const codeInput = document.getElementById('lb-classroom-code');

    linkBtn.addEventListener('click', () => this.linkClassroom());
    skipBtn.addEventListener('click', () => this.skipLinking());

    // Allow Enter key to submit
    codeInput.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') {
        this.linkClassroom();
      }
    });

    // Auto-format code (uppercase, add dash)
    codeInput.addEventListener('input', (e) => {
      let value = e.target.value.toUpperCase().replace(/[^A-Z0-9]/g, '');
      if (value.length > 3) {
        value = value.slice(0, 3) + '-' + value.slice(3, 7);
      }
      e.target.value = value;
    });
  }

  /**
   * Link to classroom using code
   */
  async linkClassroom() {
    const codeInput = document.getElementById('lb-classroom-code');
    const errorDiv = document.getElementById('lb-linking-error');
    const successDiv = document.getElementById('lb-linking-success');
    const linkBtn = document.getElementById('lb-link-classroom-btn');

    const code = codeInput.value.trim().toUpperCase();

    if (!code || code.length < 7) {
      errorDiv.textContent = 'Please enter a valid classroom code';
      errorDiv.style.display = 'block';
      return;
    }

    // Show loading
    linkBtn.textContent = 'Linking...';
    linkBtn.disabled = true;
    errorDiv.style.display = 'none';

    try {
      // Wait for config to load
      await window.ensureConfigLoaded();

      // Check if Supabase SDK is loaded
      if (!window.supabase) {
        throw new Error('Supabase SDK not loaded. Please reload the extension.');
      }

      // Query Supabase for classroom
      const supabase = window.supabase.createClient(
        window.CONFIG.supabase.url,
        window.CONFIG.supabase.anonKey
      );

      const { data, error } = await supabase
        .from('classrooms')
        .select('id, teacher_email, name')
        .eq('extension_code', code)
        .single();

      if (error || !data) {
        throw new Error('Invalid classroom code');
      }

      // Save to Chrome storage
      await chrome.storage.sync.set({
        classroom_id: data.id,
        teacher_email: data.teacher_email,
        classroom_code: code,
        classroom_name: data.name,
        hasSeenLinkingPrompt: true
      });

      // Track linking event
      if (window.LanguageBridgeAnalytics) {
        await window.LanguageBridgeAnalytics.trackEvent('classroom_linked', {
          classroom_id: data.id,
          classroom_name: data.name
        });
      }

      // Show success
      successDiv.style.display = 'block';
      linkBtn.style.display = 'none';
      document.getElementById('lb-skip-linking-btn').textContent = 'Close';

      // Auto-close after 2 seconds
      setTimeout(() => {
        this.closeModal();
      }, 2000);

    } catch (error) {
      console.error('Classroom linking error:', error);
      errorDiv.textContent = 'Invalid classroom code. Please check with your teacher.';
      errorDiv.style.display = 'block';
      linkBtn.textContent = 'Link Classroom';
      linkBtn.disabled = false;
    }
  }

  /**
   * Skip linking for now
   */
  async skipLinking() {
    await chrome.storage.sync.set({ hasSeenLinkingPrompt: true });
    this.closeModal();
  }

  /**
   * Close modal
   */
  closeModal() {
    if (this.modal) {
      this.modal.remove();
      this.modal = null;
    }
  }
}

// Create global instance
window.ClassroomLinking = new ClassroomLinking();

// Auto-show on page load if needed
(async () => {
  // Wait a bit for page to load
  await new Promise(resolve => setTimeout(resolve, 2000));

  const needsLinking = await window.ClassroomLinking.checkLinkingRequired();
  if (needsLinking) {
    await window.ClassroomLinking.showLinkingModal();
  }
})();
