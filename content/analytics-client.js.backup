/**
 * LanguageBridge Analytics - Supabase Implementation
 *
 * Privacy-First Analytics:
 * - No PII (Personally Identifiable Information) collected
 * - Anonymous user IDs generated locally
 * - All data aggregated for classroom insights only
 * - FERPA & COPPA compliant
 *
 * What we track:
 * - Translation usage (language pairs, text length)
 * - TTS usage (language, text length)
 * - Feature adoption (toolbar, floating translator, glossary)
 * - Error rates (for debugging)
 *
 * What we DON'T track:
 * - The actual text being translated
 * - Browsing history or URLs
 * - Student names or identifiers
 * - Personal information
 */

class LanguageBridgeAnalytics {
  constructor() {
    this.supabaseClient = null;
    this.userId = null;
    this.sessionId = null;
    this.enabled = false;
    this.queue = [];
    this.isInitialized = false;
    this.eventCache = new Map(); // Prevent duplicate events
  }

  /**
   * Initialize analytics with Supabase
   * Called automatically when config loads
   */
  async init() {
    try {
      // Wait for config to load
      await window.ensureConfigLoaded();

      if (!window.CONFIG.supabase.url || !window.CONFIG.supabase.anonKey) {
        console.warn('Supabase credentials not available, analytics disabled');
        return;
      }

      // Supabase SDK should be loaded from bundled lib/supabase.js
      if (!window.supabase) {
        throw new Error('Supabase SDK not loaded. Check manifest.json includes lib/supabase.js');
      }

      // Create Supabase client
      this.supabaseClient = window.supabase.createClient(
        window.CONFIG.supabase.url,
        window.CONFIG.supabase.anonKey
      );

      // Generate or retrieve anonymous user ID
      await this.initializeUserId();

      // Generate session ID
      this.sessionId = this.generateSessionId();

      this.enabled = true;
      this.isInitialized = true;

      // Process any queued events
      await this.processQueue();

      if (window.logger) {
        window.logger.log('✅ Analytics initialized (User: ' + this.userId.substring(0, 12) + '...)');
      }

      // Track session start
      await this.trackEvent('session_start', {
        extension_version: window.CONFIG.version,
        browser: this.getBrowserInfo(),
      });

    } catch (error) {
      console.warn('Analytics initialization failed:', error.message);
      this.enabled = false;
    }
  }


  /**
   * Generate or retrieve persistent anonymous user ID
   */
  async initializeUserId() {
    try {
      const stored = await chrome.storage.local.get(['analyticsUserId']);

      if (stored.analyticsUserId) {
        this.userId = stored.analyticsUserId;
      } else {
        // Generate new anonymous ID
        this.userId = 'user_' + this.generateUUID();
        await chrome.storage.local.set({ analyticsUserId: this.userId });
      }
    } catch (error) {
      // Fallback if storage fails
      this.userId = 'user_' + this.generateUUID();
    }
  }

  /**
   * Generate UUID v4
   */
  generateUUID() {
    return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {
      const r = Math.random() * 16 | 0;
      const v = c === 'x' ? r : (r & 0x3 | 0x8);
      return v.toString(16);
    });
  }

  /**
   * Generate session ID (unique per page load)
   */
  generateSessionId() {
    return 'session_' + Date.now() + '_' + Math.random().toString(36).substr(2, 9);
  }

  /**
   * Get browser information (for debugging)
   */
  getBrowserInfo() {
    return {
      userAgent: navigator.userAgent,
      language: navigator.language,
      platform: navigator.platform,
    };
  }

  /**
   * Track a generic event
   * @param {string} eventName - Name of the event
   * @param {object} properties - Event properties (must be JSON-serializable)
   */
  async trackEvent(eventName, properties = {}) {
    // If not initialized, queue the event
    if (!this.isInitialized) {
      this.queue.push({ eventName, properties, timestamp: new Date().toISOString() });
      return;
    }

    // If disabled, skip
    if (!this.enabled || !this.supabaseClient) {
      return;
    }

    // Prevent duplicate events (within 1 second)
    const cacheKey = `${eventName}_${JSON.stringify(properties)}`;
    const now = Date.now();
    if (this.eventCache.has(cacheKey)) {
      const lastTime = this.eventCache.get(cacheKey);
      if (now - lastTime < 1000) {
        return; // Skip duplicate
      }
    }
    this.eventCache.set(cacheKey, now);

    try {
      // Get classroom context from Chrome storage
      const classroomContext = await chrome.storage.sync.get([
        'classroom_id',
        'teacher_email'
      ]);

      const event = {
        user_id: this.userId,
        session_id: this.sessionId,
        event_name: eventName,
        properties: properties,
        timestamp: new Date().toISOString(),
        extension_version: window.CONFIG.version || '1.0.3',
        classroom_id: classroomContext.classroom_id || null,
        teacher_email: classroomContext.teacher_email || null,
      };

      const { error } = await this.supabaseClient
        .from('analytics_events')
        .insert([event]);

      if (error) {
        console.warn('Analytics tracking error:', error.message);

        // If table doesn't exist, disable analytics
        if (error.message.includes('relation') || error.message.includes('not found')) {
          console.warn('Analytics table not set up. Please run the SQL setup script.');
          this.enabled = false;
        }
      }
    } catch (error) {
      // Silently fail - analytics should never break the app
      console.warn('Analytics error:', error.message);
    }
  }

  /**
   * Process queued events (called after initialization)
   */
  async processQueue() {
    if (this.queue.length === 0) return;

    if (window.logger) {
      window.logger.log(`Processing ${this.queue.length} queued analytics events`);
    }

    const events = [...this.queue];
    this.queue = [];

    for (const event of events) {
      await this.trackEvent(event.eventName, event.properties);
    }
  }

  // ========================================================================
  // CONVENIENCE METHODS FOR COMMON EVENTS
  // ========================================================================

  /**
   * Track translation event
   * @param {string} fromLang - Source language code (e.g., 'en-US')
   * @param {string} toLang - Target language code (e.g., 'fa-IR')
   * @param {number} textLength - Length of translated text
   */
  async trackTranslation(fromLang, toLang, textLength) {
    await this.trackEvent('translation', {
      from_language: fromLang,
      to_language: toLang,
      text_length: textLength,
      language_pair: `${fromLang}_to_${toLang}`,
    });
  }

  /**
   * Track text-to-speech event
   * @param {string} language - Language code
   * @param {number} textLength - Length of text spoken
   */
  async trackTTS(language, textLength) {
    await this.trackEvent('tts', {
      language: language,
      text_length: textLength,
    });
  }

  /**
   * Track speech-to-text event
   * @param {string} language - Language code
   */
  async trackSTT(language) {
    await this.trackEvent('stt', {
      language: language,
    });
  }

  /**
   * Track simplification event
   * @param {string} tier - Simplification tier ('tier1', 'tier2', 'tier3')
   * @param {number} textLength - Length of simplified text
   */
  async trackSimplification(tier, textLength) {
    await this.trackEvent('simplification', {
      tier: tier,
      text_length: textLength,
    });
  }

  /**
   * Track glossary lookup
   * @param {string} language - Language code
   * @param {number} termCount - Number of terms in glossary
   */
  async trackGlossary(language, termCount) {
    await this.trackEvent('glossary', {
      language: language,
      term_count: termCount,
    });
  }

  /**
   * Track feature usage
   * @param {string} featureName - Name of feature (e.g., 'toolbar', 'floating_translator')
   * @param {string} action - Action taken (e.g., 'opened', 'closed', 'clicked')
   */
  async trackFeature(featureName, action) {
    await this.trackEvent('feature_used', {
      feature: featureName,
      action: action,
    });
  }

  /**
   * Track error
   * @param {string} errorType - Type of error (e.g., 'translation_failed', 'tts_error')
   * @param {string} errorMessage - Error message
   * @param {object} context - Additional context
   */
  async trackError(errorType, errorMessage, context = {}) {
    await this.trackEvent('error', {
      error_type: errorType,
      error_message: errorMessage,
      context: context,
    });
  }

  // ========================================================================
  // UTILITY METHODS
  // ========================================================================

  /**
   * Get current analytics stats (for debugging)
   */
  async getStats() {
    if (!this.enabled || !this.supabaseClient) {
      return { error: 'Analytics not enabled' };
    }

    try {
      const { data, error } = await this.supabaseClient
        .from('analytics_events')
        .select('event_name')
        .eq('user_id', this.userId);

      if (error) throw error;

      // Count events by type
      const stats = {};
      data.forEach(event => {
        stats[event.event_name] = (stats[event.event_name] || 0) + 1;
      });

      return {
        userId: this.userId,
        sessionId: this.sessionId,
        totalEvents: data.length,
        eventBreakdown: stats,
      };
    } catch (error) {
      return { error: error.message };
    }
  }

  /**
   * Check if analytics is enabled
   */
  isEnabled() {
    return this.enabled;
  }

  /**
   * Disable analytics (respects user privacy settings)
   */
  disable() {
    this.enabled = false;
    if (window.logger) {
      window.logger.log('Analytics disabled by user');
    }
  }
}

// ============================================================================
// GLOBAL INSTANCE & AUTO-INITIALIZATION
// ============================================================================

// Create global instance
window.LanguageBridgeAnalytics = new LanguageBridgeAnalytics();

// Auto-initialize when config is ready
(async () => {
  try {
    // Wait a bit to ensure config.js has loaded
    await new Promise(resolve => setTimeout(resolve, 100));

    // Initialize analytics
    await window.LanguageBridgeAnalytics.init();
  } catch (error) {
    console.warn('Analytics auto-initialization failed:', error.message);
  }
})();
